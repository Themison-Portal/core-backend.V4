# Environment Variables for Backend
# Copy this file to .env and fill in your values

# ===================
# API Keys (Required)
# ===================

# OpenAI API (for embeddings)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API (for Claude LLM)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Upload/Query endpoint API key (X-API-KEY header)
UPLOAD_API_KEY=your-upload-api-key

# ===================
# Database & Cache (Required)
# ===================

# PostgreSQL (Docker - port 54322)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# Redis (Docker - port 6379)
REDIS_URL=redis://localhost:6379

# ===================
# Auth0 Configuration
# ===================

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.themison.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH_DISABLED=false  # Set to true to bypass Auth0 for local testing

# ===================
# Frontend (CORS)
# ===================

FRONTEND_URL=http://localhost:8080

# ===================
# gRPC RAG Service (Optional)
# ===================

RAG_SERVICE_ADDRESS=localhost:50051
USE_GRPC_RAG=false  # Feature flag for gRPC routing

# ===================
# Google Cloud Storage (Optional)
# ===================

# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET_TRIAL_DOCUMENTS=your-bucket
# GCS_BUCKET_PATIENT_DOCUMENTS=your-bucket
# GCS_CREDENTIALS_PATH=./gcs-credentials.json
