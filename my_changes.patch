From 715e8a27f46824520b0af45fb47e7b5ccde33e97 Mon Sep 17 00:00:00 2001
From: jonaathan22 <jonaath.k@gmail.com>
Date: Wed, 4 Mar 2026 17:25:57 +0530
Subject: [PATCH 13/14] Fix: pre-bake HuggingFace tokenizer model into Docker
 image to fix Cloud Run cold-start crashes

---
 Dockerfile | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/Dockerfile b/Dockerfile
index a3099d5..0b80661 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -24,6 +24,14 @@ RUN mkdir -p uploads
 ENV PYTHONUNBUFFERED=1
 ENV PYTHONPATH=/app
 
+# Pre-download HuggingFace tokenizer model at build time
+# so Cloud Run never needs internet access to HuggingFace on startup
+RUN python -c "from transformers import AutoTokenizer; AutoTokenizer.from_pretrained('sentence-transformers/all-MiniLM-L6-v2')"
+
+# Tell HuggingFace to use only cached models - no runtime downloads
+ENV TRANSFORMERS_OFFLINE=1
+ENV HF_DATASETS_OFFLINE=1
+
 # Expose port (Cloud Run defaults to 8080)
 EXPOSE 8080
 
