+# =====================================================
+# Docker Environment ΓÇö copy to .env before running
+# =====================================================
+#
+#   cp docker/.env.docker .env
+#   # Fill in your API keys below, then:
+#   docker-compose up -d --build
+#
+# This file has the correct defaults for running the
+# full stack in Docker (backend + rag-service + db + redis).
+# Seed data is auto-loaded on first startup (docker/seed.sql).
+#
+# Swagger UI: http://localhost:8000/docs
+# =====================================================
+
+# ===================
+# API Keys (Required ΓÇö fill these in)
+# ===================
+
+OPENAI_API_KEY=sk-proj-your-openai-key-here
+ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here
+
+# Used as X-API-KEY header for /upload and /query endpoints
+UPLOAD_API_KEY=dev-test-key-123
+
+# ===================
+# Auth (disabled for Docker testing)
+# ===================
+
+# Bypasses Auth0 JWT ΓÇö uses the seeded test member automatically.
+# No Bearer token needed in Swagger.
+AUTH_DISABLED=true
+
+# ===================
+# gRPC RAG Service (enabled for Docker)
+# ===================
+
+# Routes PDF ingestion and queries through the rag-service container.
+USE_GRPC_RAG=true
+
+# ===================
+# Database & Cache
+# ===================
+
+# These are only used when running the backend OUTSIDE Docker
+# (e.g. uvicorn locally). Inside Docker, docker-compose.yml
+# overrides them with internal hostnames (db:5432, redis:6379).
+DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres
+REDIS_URL=redis://localhost:6379
+
+# ===================
+# Frontend (CORS)
+# ===================
+
+FRONTEND_URL=http://localhost:8080
+ALLOW_ALL_ORIGINS=true
+
+# ===================
+# Google Cloud Storage (not needed for local Docker)
+# ===================
+
+# Leave empty ΓÇö backend uses LocalStorageService automatically.
+# Files are saved to ./uploads/ and served via /local-files/ endpoint.
+# GCS_PROJECT_ID=
+# GCS_BUCKET_TRIAL_DOCUMENTS=
+# GCS_BUCKET_PATIENT_DOCUMENTS=
+# GCS_CREDENTIALS_PATH=
+
+# =====================================================
+# Quick-start after docker-compose up:
+#
+#   Trial ID:  50000000-0000-0000-0000-000000000001
+#   API Key:   dev-test-key-123  (X-API-KEY header)
+#
+#   1. POST /api/trial-documents/upload
+#      trial_id = 50000000-0000-0000-0000-000000000001
+#      (attach any PDF)
+#
+#   2. POST /upload/upload-pdf
+#      { "document_url": "<from step 1>",
+#        "document_id": "<from step 1>" }
+#
+#   3. GET  /upload/status/{job_id}
+#      (poll until status = "completed")
+#
+#   4. POST /query
+#      { "query": "What are the inclusion criteria?",
+#        "document_id": "<from step 1>",
+#        "document_name": "Clinical Protocol" }
+# =====================================================
