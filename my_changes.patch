+
+        parsed = client._parse_ingest_result(mock_result)
+
+        assert parsed["success"] is False
+        assert parsed["error"] == "PDF parsing failed"
+
+    def test_parse_query_response(self, client):
+        """Test parsing QueryResponse protobuf."""
